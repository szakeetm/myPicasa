{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "myPicasa",
  "version": "1.0.0",
  "identifier": "com.martonady.mypicasa",
  "build": {
    "beforeDevCommand": "cd frontend && npm run dev -- --host 127.0.0.1 --port 1420",
    "beforeBuildCommand": "cd frontend && npm run build",
    "beforeBundleCommand": "node scripts/cleanup-bundle.mjs",
    "frontendDist": "../frontend/dist",
    "devUrl": "http://127.0.0.1:1420"
  },
  "app": {
    "windows": [
      {
        "title": "myPicasa",
        "width": 1440,
        "height": 960,
        "minWidth": 1024,
        "minHeight": 720
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$APPDATA/thumbnail-cache/**/*.jpg",
          "$APPDATA/preview-cache/**/*.jpg",
          "$APPDATA/viewer-cache/**/*.jpg",
          "$APPDATA/viewer-cache/**/*.mp4",
          "$HOME/**/*.jpg",
          "/Volumes/**/*.jpg",
          "$HOME/**/*.mp4",
          "$HOME/**/*.m4v",
          "$HOME/**/*.mov",
          "$HOME/**/*.webm",
          "/Volumes/**/*.mp4",
          "/Volumes/**/*.m4v",
          "/Volumes/**/*.mov",
          "/Volumes/**/*.webm"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ]
  }
}
